OPENAI_KEY_ENCRYPTION_SECRET=change-me-encryption-secret
OPENAI_API_KEY=your-service-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
NANO_BANANA_PROVIDER=vertex
# NANO_BANANA_PROVIDER=gemini_api일 때만 필요하며 Secret Manager 주입을 권장한다.
GEMINI_API_KEY=
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
NANO_BANANA_PROJECT_ID=sapient-stacker-468504-r6
NANO_BANANA_LOCATION=global
NANO_BANANA_PROMPT_VERSION=csat_v1
# 비워 두면 02_main/vendor/hwpxskill-math를 기본 runtime bundle로 사용한다.
# HWPX_SKILL_DIR=
# HWPX export engine: legacy | auto | hwpforge
HWPX_EXPORT_ENGINE=auto
# HwpForge MCP runtime이 별도 위치에 있으면 절대 경로로 지정한다.
# HWPFORGE_MCP_PATH=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# 비대칭 JWT를 쓰는 프로젝트에서는 선택값이며, HS256 로컬 helper fallback용이다.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET=ocr-assets
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_SERVER=production
POLAR_PRODUCT_SINGLE_ID=prod_xxx_single
POLAR_PRODUCT_STARTER_ID=prod_xxx_starter
POLAR_PRODUCT_PRO_ID=prod_xxx_pro
APP_URL=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Cloud Tasks 비동기 worker 설정
# 현재 운영 로그/배포 이력 기준 GCP 프로젝트 ID
GCP_PROJECT_ID=sapient-stacker-468504-r6
# 현재 운영 Cloud Run 리전
GCP_REGION=us-central1
# 아직 queue를 만들지 않았다면 이 이름으로 생성하는 것을 권장
PIPELINE_TASK_QUEUE=mathocr-job-tasks
# 참고: 현재 Cloud Run 런타임 서비스 계정은 146126176673-compute@developer.gserviceaccount.com
# 아래 서비스 계정은 아직 실제 생성 여부를 저장소만으로 확정할 수 없다.
# 권장값: GCP IAM에서 이 이름으로 서비스 계정을 생성하고 그대로 사용
PIPELINE_TASK_CALLER_SERVICE_ACCOUNT=mathocr-worker-invoker@sapient-stacker-468504-r6.iam.gserviceaccount.com
# 현재 gcloud 조회 기준 Cloud Run 서비스 기본 URL
CLOUD_RUN_SERVICE_URL=https://mathocr-tmkhqnytsa-uc.a.run.app
# Cloud Scheduler -> Cloud Run maintenance purge shared secret
MAINTENANCE_JOB_TOKEN=change-me-maintenance-token
