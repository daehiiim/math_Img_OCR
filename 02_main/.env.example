OPENAI_KEY_ENCRYPTION_SECRET=change-me-encryption-secret
OPENAI_API_KEY=your-service-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
NANO_BANANA_PROVIDER=vertex
# NANO_BANANA_PROVIDER=gemini_api일 때만 필요하며 Secret Manager 주입을 권장한다.
GEMINI_API_KEY=
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
NANO_BANANA_PROJECT_ID=your-gcp-project-id
NANO_BANANA_LOCATION=global
NANO_BANANA_PROMPT_VERSION=csat_v1
# 비워 두면 02_main/vendor/hwpxskill-math를 기본 runtime bundle로 사용한다.
# HWPX_SKILL_DIR=
# HWPX export engine: legacy | auto | hwpforge
HWPX_EXPORT_ENGINE=auto
# HwpForge MCP runtime이 별도 위치에 있으면 절대 경로로 지정한다.
# HWPFORGE_MCP_PATH=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# 비대칭 JWT를 쓰는 프로젝트에서는 선택값이며, HS256 로컬 helper fallback용이다.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET=ocr-assets
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_SERVER=production
POLAR_PRODUCT_SINGLE_ID=prod_xxx_single
POLAR_PRODUCT_STARTER_ID=prod_xxx_starter
POLAR_PRODUCT_PRO_ID=prod_xxx_pro
APP_URL=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
