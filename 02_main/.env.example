OPENAI_API_KEY=your-service-openai-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
APP_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# 비대칭 JWT를 쓰는 프로젝트에서는 선택값이며, HS256 로컬 helper fallback용이다.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET=ocr-assets
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_SERVER=sandbox
POLAR_PRODUCT_SINGLE_ID=prod_xxx_single
POLAR_PRODUCT_STARTER_ID=prod_xxx_starter
POLAR_PRODUCT_PRO_ID=prod_xxx_pro
# 운영에서는 https://mathtohwp.vercel.app 만 넣고, 로컬은 development 기본값을 쓴다.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 필요할 때만 명시한다. production 에서는 비워 두거나 제거한다.
CORS_ALLOW_ORIGIN_REGEX=
