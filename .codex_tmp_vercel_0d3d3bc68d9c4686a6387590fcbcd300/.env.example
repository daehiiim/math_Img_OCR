VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# 운영 Vercel 배포는 same-origin 프록시를 사용하므로 기본값으로 비워 둔다.
VITE_API_BASE_URL=
# 로컬 개발에서만 필요하면 아래 값을 사용한다.
# VITE_API_BASE_URL=http://localhost:8000
# 로컬 UI mock 로그인/결제 테스트가 필요할 때만 켠다.
VITE_LOCAL_UI_MOCK=false
# mock 결제 기본 결과값. 현재 결제 페이지의 ?mock_payment=... 가 있으면 그 값이 우선한다.
VITE_LOCAL_UI_MOCK_PAYMENT_OUTCOME=success
